server:
  host: 0.0.0.0
  port: 8488
auth:
  apiKey: your-api-key-here
  loginSecret: your-login-secret-here
storage:
  type: sqlite
  path: ./data/proxycli.db
# 控制是否将思维链返回到前端
# 启用后，思维链会在响应的 reasoning_content 字段中返回
# 禁用后，思维链会在响应中被过滤掉
# 默认值: true
returnThoughtsToFrontend: true
gemini:
  defaultModel: gemini-2.5-flash
  apiEndpoint: https://cloudcode-pa.googleapis.com/v1internal
  supportedModels:
    - gemini-3.1-pro-preview
    - gemini-3.1-pro-preview-customtools
    - gemini-3-pro-preview
    - gemini-3-flash-preview
    - gemini-2.5-pro
    - gemini-2.5-flash
    - gemini-2.5-flash-lite
    # High thinking level variants
    - gemini-2.5-pro-high
    - gemini-2.5-flash-high
    - gemini-2.5-flash-lite-high
    - gemini-3-pro-high
    - gemini-3-flash-high
    - gemini-3.1-pro-high
    # Medium thinking level variants
    - gemini-2.5-pro-medium
    - gemini-2.5-flash-medium
    - gemini-3-flash-medium
    # Low thinking level variants
    - gemini-2.5-pro-low
    - gemini-2.5-flash-low
    # Minimal thinking level variants (flash only)
    - gemini-2.5-flash-minimal
    # Max thinking level variants
    - gemini-2.5-pro-max
    - gemini-2.5-flash-max
    # Parentheses format for thinking budget
    - gemini-2.5-pro(high)
    - gemini-2.5-flash(high)
    - gemini-2.5-pro(medium)
    - gemini-2.5-flash(medium)
    - gemini-2.5-pro(low)
    - gemini-2.5-flash(low)
    - gemini-2.5-flash(minimal)
    - gemini-2.5-pro(max)
    - gemini-2.5-flash(max)
    - gemini-2.5-pro(24576)
    - gemini-2.5-flash(24576)
    - gemini-2.5-pro(8192)
    - gemini-2.5-flash(8192)
    - gemini-2.5-pro(1024)
    - gemini-2.5-flash(1024)
    - gemini-3-pro(high)
    - gemini-3-flash(high)
    - gemini-3-pro(medium)
    - gemini-3-flash(medium)
    - gemini-3-flash(low)
  modelAliases:
    gemini-pro-latest: gemini-2.5-pro
    gemini-flash-latest: gemini-2.5-flash
    gemini-flash-lite-latest: gemini-2.5-flash-lite
    # High thinking level variants
    gemini-2.5-pro-high: gemini-2.5-pro
    gemini-2.5-flash-high: gemini-2.5-flash
    gemini-2.5-flash-lite-high: gemini-2.5-flash-lite
    gemini-3-pro-high: gemini-3-pro-preview
    gemini-3-flash-high: gemini-3-flash-preview
    gemini-3.1-pro-high: gemini-3.1-pro-preview
    # Medium thinking level variants
    gemini-2.5-pro-medium: gemini-2.5-pro
    gemini-2.5-flash-medium: gemini-2.5-flash
    gemini-3-flash-medium: gemini-3-flash-preview
    # Low thinking level variants
    gemini-2.5-pro-low: gemini-2.5-pro
    gemini-2.5-flash-low: gemini-2.5-flash
    # Minimal thinking level variants (flash only)
    gemini-2.5-flash-minimal: gemini-2.5-flash
  excludedModels: []
codex:
  enabled: true
  supportedModels:
    - gpt-5.3-codex
    - gpt-5.2
    - gpt-5.2-codex
    - gpt-5.1
    - gpt-5.1-codex
    - gpt-5.1-codex-mini
    - gpt-5.1-codex-max
    - gpt-5
    - gpt-5-codex
    - gpt-5-codex-mini
  modelAliases:
    codex-latest: gpt-5.3-codex
  excludedModels: []
iflow:
  enabled: true
  supportedModels:
    - glm-5
    - glm-4.7
    - glm-4.6
    - deepseek-v3.2-chat
    - deepseek-v3.2-reasoner
    - deepseek-v3.2
    - deepseek-v3.1
    - deepseek-r1
    - deepseek-v3
    - qwen3-coder-plus
    - qwen3-max
    - qwen3-max-preview
    - qwen3-vl-plus
    - qwen3-235b-a22b-thinking-2507
    - qwen3-235b-a22b-instruct
    - qwen3-235b
    - qwen3-32b
    - kimi-k2.5
    - kimi-k2
    - kimi-k2-thinking
    - kimi-k2-0905
    - minimax-m2.5
    - minimax-m2.1
    - minimax-m2
    - tstars2.0
    - iflow-rome-30ba3b
  modelAliases:
    deepseek-chat: deepseek-v3.2-chat
    deepseek-reasoner: deepseek-v3.2-reasoner
  excludedModels: []
qwen:
  enabled: false
  supportedModels: []
  modelAliases: {}
  excludedModels: []
kimi:
  enabled: false
  supportedModels: []
  modelAliases: {}
  excludedModels: []
# OAuth 配置说明:
# - gemini: 需要配置 clientId 和 clientSecret（使用下方默认值或自己的 OAuth 应用）
# - codex 和 iflow: 【重要】不要配置！代码内置了默认凭证，配置后会覆盖默认值导致授权失败
#   如果配置了 codex/iflow 节点但值是占位符（如 "your-xxx"），OAuth 会失败！
#   正确做法：直接删除 codex 和 iflow 节点，让代码使用内置默认值
oauth:
  gemini:
    clientId: 681255809395-oo8ft2oprdrnp9e3aqf6av3hmdib135j.apps.googleusercontent.com
    clientSecret: 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
    scopes:
      - https://www.googleapis.com/auth/cloud-platform
      - https://www.googleapis.com/auth/userinfo.email
      - https://www.googleapis.com/auth/userinfo.profile
  # codex 和 iflow 使用内置默认凭证，请勿配置！
  # 如果需要自定义，请确保 clientId 等字段是有效值，不能是占位符
routing:
  strategy: round-robin
retry:
  maxRetries: 3
  baseIntervalMs: 5000
  backoffMultiplier: 2
  maxIntervalMs: 30000
management:
  enabled: true
  secret: ""
logging:
  level: info
proxy: ""

# Note: OpenAI-compatible providers can be added dynamically via the admin panel
# or through the management API at /v0/management/openai-compat/providers
