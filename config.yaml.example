server:
  host: 0.0.0.0
  port: 8488
auth:
  apiKey: your-api-key-here
  loginSecret: your-login-secret-here
storage:
  type: sqlite
  path: ./data/proxycli.db
gemini:
  defaultModel: gemini-2.5-flash
  apiEndpoint: https://cloudcode-pa.googleapis.com/v1internal
  supportedModels:
    - gemini-3.1-pro-preview
    - gemini-3.1-pro-preview-customtools
    - gemini-3-pro-preview
    - gemini-3-flash-preview
    - gemini-2.5-pro
    - gemini-2.5-flash
    - gemini-2.5-flash-lite
  modelAliases:
    gemini-pro-latest: gemini-2.5-pro
    gemini-flash-latest: gemini-2.5-flash
    gemini-flash-lite-latest: gemini-2.5-flash-lite
  excludedModels: []
codex:
  enabled: true
  supportedModels:
    - gpt-5.3-codex
    - gpt-5.2
    - gpt-5.2-codex
    - gpt-5.1
    - gpt-5.1-codex
    - gpt-5.1-codex-mini
    - gpt-5.1-codex-max
    - gpt-5
    - gpt-5-codex
    - gpt-5-codex-mini
  modelAliases:
    codex-latest: gpt-5.3-codex
  excludedModels: []
iflow:
  enabled: true
  supportedModels:
    - glm-5
    - glm-4.7
    - glm-4.6
    - deepseek-v3.2-chat
    - deepseek-v3.2-reasoner
    - deepseek-v3.2
    - deepseek-v3.1
    - deepseek-r1
    - deepseek-v3
    - qwen3-coder-plus
    - qwen3-max
    - qwen3-max-preview
    - qwen3-vl-plus
    - qwen3-235b-a22b-thinking-2507
    - qwen3-235b-a22b-instruct
    - qwen3-235b
    - qwen3-32b
    - kimi-k2.5
    - kimi-k2
    - kimi-k2-thinking
    - kimi-k2-0905
    - minimax-m2.5
    - minimax-m2.1
    - minimax-m2
    - tstars2.0
    - iflow-rome-30ba3b
  modelAliases:
    deepseek-chat: deepseek-v3.2-chat
    deepseek-reasoner: deepseek-v3.2-reasoner
  excludedModels: []
qwen:
  enabled: false
  supportedModels: []
  modelAliases: {}
  excludedModels: []
kimi:
  enabled: false
  supportedModels: []
  modelAliases: {}
  excludedModels: []
# Gemini CLI OAuth credentials (参考 https://github.com/Tennki182/CLIProxyAPI)
# 如果要使用自己的 OAuth 应用，请替换以下 clientId 和 clientSecret
oauth:
  gemini:
    clientId: 681255809395-oo8ft2oprdrnp9e3aqf6av3hmdib135j.apps.googleusercontent.com
    clientSecret: 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
    scopes:
      - https://www.googleapis.com/auth/cloud-platform
      - https://www.googleapis.com/auth/userinfo.email
      - https://www.googleapis.com/auth/userinfo.profile
  codex:
    clientId: your-codex-client-id
    authEndpoint: https://auth.openai.com/oauth/authorize
    tokenEndpoint: https://auth.openai.com/oauth/token
    apiBase: https://chatgpt.com/backend-api/codex
  iflow:
    clientId: "your-iflow-client-id"
    clientSecret: your-iflow-client-secret
    authEndpoint: https://iflow.cn/oauth
    tokenEndpoint: https://iflow.cn/oauth/token
    userinfoEndpoint: https://iflow.cn/api/oauth/getUserInfo
    apiBase: https://apis.iflow.cn/v1
routing:
  strategy: round-robin
retry:
  maxRetries: 3
  baseIntervalMs: 5000
  backoffMultiplier: 2
  maxIntervalMs: 30000
management:
  enabled: true
  secret: ""
logging:
  level: info
proxy: ""

# Note: OpenAI-compatible providers can be added dynamically via the admin panel
# or through the management API at /v0/management/openai-compat/providers
